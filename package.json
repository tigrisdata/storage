{
  "name": "@tigris/monorepo",
  "version": "0.0.1",
  "description": "Tigris monorepo for storage SDK",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/storage",
    "packages/iam",
    "packages/agent-kit",
    "packages/keyv-tigris",
    "packages/react"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "publint": "npm run publint --workspaces --if-present",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check",
    "check:fix": "biome check --write",
    "test": "npm run test --workspaces --if-present",
    "commit": "cz",
    "release": "./scripts/release.sh",
    "release:dry-run": "./scripts/release.sh --dry-run",
    "prepare": "husky install",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules/.cache"
  },
  "keywords": [
    "object",
    "storage",
    "tigris",
    "blob",
    "ai"
  ],
  "author": "Tigris Data",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tigrisdata/storage.git"
  },
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "scope-empty": [
        2,
        "never"
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "publint": "^0.3.18",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
